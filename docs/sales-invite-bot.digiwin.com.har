              "value": "{\"group\":\"cf-nel\",\"max_age\":604800,\"endpoints\":[{\"url\":\"https://a.nel.cloudflare.com/report/v4?s=upafM1k2E%2FQuq%2BfP1aKZYDXm8sQOxRdE7xdHqs3QTpnMoW0GN%2BPYwdCrBrhedjT66d72gmdnmsaklw1hgQEflIZmNUg8ZrbebpPEe2TGMj4ySQpHato92RZYhsqxlG%2BGpgjYOYbXpRfvJ%2BbLSegL\"}]}"
