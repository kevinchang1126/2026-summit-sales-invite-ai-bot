          ],
          "cookies": [],
          "content": {
            "size": 14282,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no\">\n  <title>2026 鼎新企業高峰年會 — 邀約說帖產生器</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"style.css\">\n</head>\n\n<body>\n  <!-- 頂部導覽 -->\n  <header class=\"header\">\n    <div class=\"header-inner\">\n      <h1 class=\"logo\">鼎新年會<span>邀約助手</span></h1>\n      <nav class=\"tabs\">\n        <button class=\"tab active\" data-tab=\"generate\">生成說帖</button>\n        <button class=\"tab\" data-tab=\"leaderboard\">排行榜</button>\n        <button class=\"tab\" data-tab=\"history\">我的記錄</button>\n      </nav>\n    </div>\n  </header>\n\n  <main class=\"container\">\n    <!-- ===== 生成說帖頁 ===== -->\n    <section id=\"tab-generate\" class=\"tab-content active\">\n      <div class=\"card\">\n        <h2 class=\"card-title\">填寫客戶資訊</h2>\n        <form id=\"form-generate\">\n          <!-- 必填 -->\n          <div class=\"form-group\">\n            <label class=\"required\">客戶產業別</label>\n            <select name=\"industry\" required>\n              <option value=\"\">請選擇</option>\n              <option value=\"製造業\">製造業（通用）</option>\n              <option value=\"電子/半導體\">電子／半導體</option>\n              <option value=\"食品/飲料\">食品／飲料</option>\n              <option value=\"流通/批發\">流通／批發</option>\n              <option value=\"零售/電商\">零售／電商</option>\n              <option value=\"餐飲連鎖\">餐飲連鎖</option>\n              <option value=\"戶外/運動用品\">戶外／運動用品</option>\n            </select>\n          </div>\n\n          <div class=\"form-group\">\n            <label class=\"required\">邀約對象職能</label>\n            <select name=\"role\" required>\n              <option value=\"\">請選擇</option>\n              <option value=\"企業主/董事長/總經理\">企業主／董事長／總經理</option>\n              <option value=\"副總/資訊長/技術主管\">副總／資訊長／技術主管</option>\n              <option value=\"廠長/生產主管\">廠長／生產主管</option>\n              <option value=\"營運長/供應鏈主管\">營運長／供應鏈主管</option>\n              <option value=\"行銷/業務主管\">行銷／業務主管</option>\n            </select>\n          </div>\n\n          <div class=\"form-group\">\n            <label class=\"required\">邀約管道</label>\n            <div class=\"radio-group\">\n              <label class=\"radio-label\"><input type=\"radio\" name=\"channel\" value=\"電話話術\" required> 電話話術</label>\n              <label class=\"radio-label\"><input type=\"radio\" name=\"channel\" value=\"LINE訊息\"> LINE 訊息</label>\n              <label class=\"radio-label\"><input type=\"radio\" name=\"channel\" value=\"Email\"> Email</label>\n            </div>\n          </div>\n\n          <!-- 選填 -->\n          <details class=\"optional-section\">\n            <summary>更多選填資訊（提供越多越精準）</summary>\n\n            <div class=\"form-group\">\n              <label>客戶公司規模</label>\n              <select name=\"scale\">\n                <option value=\"\">不指定</option>\n                <option value=\"50人以下\">50人以下</option>\n                <option value=\"50-200人\">50–200人</option>\n                <option value=\"200-500人\">200–500人</option>\n                <option value=\"500-1000人\">500–1000人</option>\n                <option value=\"1000人以上\">1000人以上</option>\n              </select>\n            </div>\n\n            <div class=\"form-group\">\n              <label>已知痛點或背景</label>\n              <textarea name=\"pain_points\" rows=\"2\" placeholder=\"例：最近在評估 AI 導入、缺工嚴重...\"></textarea>\n            </div>\n\n            <div class=\"form-group\">\n              <label>場次偏好</label>\n              <div class=\"radio-group\">\n                <label class=\"radio-label\"><input type=\"radio\" name=\"session_pref\" value=\"製造分場\"> 製造分場</label>\n                <label class=\"radio-label\"><input type=\"radio\" name=\"session_pref\" value=\"流通分場\"> 流通分場</label>\n              </div>\n            </div>\n\n            <div class=\"form-group\">\n              <label>客戶類型</label>\n              <select name=\"customer_type\">\n                <option value=\"\">不指定</option>\n                <option value=\"有接觸的老客戶\">有接觸的老客戶</option>\n                <option value=\"無接觸的老客戶\">無接觸的老客戶</option>\n                <option value=\"有接觸的新客戶\">有接觸的新客戶</option>\n                <option value=\"無接觸的新客戶\">無接觸的新客戶</option>\n              </select>\n            </div>\n\n            <div class=\"form-group\">\n              <label>客戶偏好風格</label>\n              <div class=\"radio-group\">\n                <label class=\"radio-label\"><input type=\"radio\" name=\"style\" value=\"務實派\"> 務實派（眼見為憑）</label>\n                <label class=\"radio-label\"><input type=\"radio\" name=\"style\" value=\"願景型\"> 願景型（整體藍圖）</label>\n              </div>\n            </div>\n\n            <div class=\"form-group\">\n              <label>你的暱稱（顯示在排行榜）</label>\n              <input type=\"text\" name=\"author\" placeholder=\"例：Kevin\" maxlength=\"20\">\n            </div>\n          </details>\n\n          <button type=\"submit\" class=\"btn-primary\" id=\"btn-generate\">\n            <span class=\"btn-text\">生成邀約說帖</span>\n            <span class=\"btn-loading\" style=\"display:none\">\n              <span class=\"spinner\"></span> AI 生成中...\n            </span>\n          </button>\n        </form>\n      </div>\n\n      <!-- 結果區 -->\n      <div id=\"result-area\" class=\"card\" style=\"display:none\">\n        <div class=\"result-header\">\n          <h2 class=\"card-title\">生成結果</h2>\n          <div class=\"result-actions\">\n            <button class=\"btn-icon\" id=\"btn-copy\" title=\"複製內容\">\n              <svg width=\"20\" height=\"20\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                <rect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\" />\n                <path d=\"M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1\" />\n              </svg>\n            </button>\n          </div>\n        </div>\n        <!-- 顯示模式 -->\n        <div id=\"result-display\">\n          <div id=\"result-content\" class=\"result-content\"></div>\n        </div>\n        <!-- 編輯模式 -->\n        <div id=\"result-edit\" style=\"display:none\">\n          <textarea id=\"edit-textarea\" class=\"edit-textarea\"></textarea>\n        </div>\n\n        <!-- 操作列 -->\n        <div class=\"result-footer\">\n          <button class=\"btn-vote btn-like\" data-vote=\"like\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M14 9V5a3 3 0 00-3-3l-4 9v11h11.28a2 2 0 002-1.7l1.38-9a2 2 0 00-2-2.3H14z\" />\n              <path d=\"M7 22H4a2 2 0 01-2-2v-7a2 2 0 012-2h3\" />\n            </svg>\n            好用\n          </button>\n          <button class=\"btn-vote btn-dislike\" data-vote=\"dislike\">\n            <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path d=\"M10 15V19a3 3 0 003 3l4-9V2H5.72a2 2 0 00-2 1.7l-1.38 9a2 2 0 002 2.3H10z\" />\n              <path d=\"M17 2h2.67A2.31 2.31 0 0122 4v7a2.31 2.31 0 01-2.33 2H17\" />\n            </svg>\n            需改善\n          </button>\n          <button class=\"btn-secondary\" id=\"btn-edit\">編輯</button>\n          <button class=\"btn-secondary\" id=\"btn-save-edit\" style=\"display:none\">儲存</button>\n          <button class=\"btn-secondary\" id=\"btn-cancel-edit\" style=\"display:none\">取消</button>\n          <button class=\"btn-secondary\" id=\"btn-regenerate\">重新生成</button>\n        </div>\n\n        <!-- AI 微調區 -->\n        <div class=\"refine-section\">\n          <h3 class=\"refine-title\">AI 微調</h3>\n          <div class=\"refine-chips\">\n            <button class=\"refine-chip\" data-instruction=\"請讓語氣更親切、像朋