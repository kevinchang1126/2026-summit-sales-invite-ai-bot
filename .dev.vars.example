# 本檔案提供為環境變數設定範例 (Environment Variables Example)
# 請將此檔案複製並重新命名為 .dev.vars，然後將底下的值替換成您真實的 API Key。
# DO NOT COMMIT your actual .dev.vars file!

# Google Gemini API Key
GEMINI_API_KEY="your_gemini_api_key_here"

# Anthropic Claude API Key (If used)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# (Optional) Database URL or other external service configurations
# DB_HOST="your_db_host"
